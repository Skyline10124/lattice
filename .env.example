# ─── Artemis Provider Credentials ───────────────────────────────────────
# Copy this file to .env and fill in your keys.
# Only variables that are set will be used; unset ones are ignored.
# Keys are resolved in priority order per provider (see router.rs).

# ─── Major Providers ────────────────────────────────────────────────────
# Anthropic (claude-sonnet-4-6, claude-opus-4-7, etc.)
ANTHROPIC_API_KEY=

# OpenAI (gpt-4.1, o3, etc.)
OPENAI_API_KEY=

# Google Gemini (gemini-2.5-pro, etc.)
GEMINI_API_KEY=

# DeepSeek (deepseek-chat, deepseek-reasoner)
DEEPSEEK_API_KEY=

# Mistral (mistral-large-latest, etc.)
MISTRAL_API_KEY=

# Groq (llama-4-scout on Groq infra)
GROQ_API_KEY=

# xAI (grok-3, etc.)
XAI_API_KEY=

# ─── Aggregators / Gateways ─────────────────────────────────────────────
# OpenRouter (access to 100+ models via single key)
OPENROUTER_API_KEY=

# AI Gateway (shared gateway endpoint)
AI_GATEWAY_API_KEY=

# ─── Chinese Providers ──────────────────────────────────────────────────
# Volces / ByteDance Ark (doubao, etc.)
ARK_API_KEY=

# Qwen / Alibaba (qwen-max, qwen-plus, etc.)
QWEN_API_KEY=

# Infini AI (domestic aggregator)
INFINI_AI_API_KEY=

# MiniMax (minimax-m1, etc.)
MINIMAX_API_KEY=

# ─── IDE / Tool Providers ───────────────────────────────────────────────
# Nous (NousResearch models)
NOUS_API_KEY=

# GitHub Copilot (copilot-hosted models)
GITHUB_TOKEN=

# OpenCode Zen
OPENCODE_ZEN_API_KEY=

# Kilocode
KILO_API_KEY=

# OpenCode Go (14 models)
OPENCODE_GO_API_KEY=

# ─── Local / No Key Required ────────────────────────────────────────────
# Ollama runs locally and needs no API key.
# Just ensure ollama is running on localhost:11434.
